{
  "uid": "clusterpulse-node-detail",
  "title": "ClusterPulse - Node Detail",
  "tags": ["clusterpulse"],
  "timezone": "utc",
  "schemaVersion": 39,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "node",
        "label": "Node",
        "type": "query",
        "datasource": { "type": "grafana-postgresql-datasource", "uid": "clusterpulse-postgres" },
        "query": "SELECT node_id FROM nodes ORDER BY node_id;",
        "refresh": 2,
        "includeAll": false,
        "multi": false
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "CPU Usage (%)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "clusterpulse-postgres" },
      "targets": [
        {
          "refId": "A",
          "format": "time_series",
          "rawSql": "SELECT $__time(collected_at), value FROM metric_samples WHERE $__timeFilter(collected_at) AND node_id = '$node' AND metric_type = 'cpu.usage_percent' ORDER BY collected_at;"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "percent", "max": 100, "min": 0, "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Memory Usage (%)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "clusterpulse-postgres" },
      "targets": [
        {
          "refId": "A",
          "format": "time_series",
          "rawSql": "SELECT $__time(collected_at), value FROM metric_samples WHERE $__timeFilter(collected_at) AND node_id = '$node' AND metric_type = 'memory.usage_percent' ORDER BY collected_at;"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "percent", "max": 100, "min": 0, "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Disk Usage (%)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "clusterpulse-postgres" },
      "targets": [
        {
          "refId": "A",
          "format": "time_series",
          "rawSql": "SELECT $__time(collected_at), value FROM metric_samples WHERE $__timeFilter(collected_at) AND node_id = '$node' AND metric_type = 'disk.usage_percent' ORDER BY collected_at;"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent", "max": 100, "min": 0,
          "custom": { "drawStyle": "line", "fillOpacity": 10 },
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "red", "value": 85 } ] }
        },
        "overrides": []
      }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Network Bytes (cumulative)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "clusterpulse-postgres" },
      "targets": [
        {
          "refId": "A",
          "format": "time_series",
          "rawSql": "SELECT $__time(collected_at), metric_type AS metric, value FROM metric_samples WHERE $__timeFilter(collected_at) AND node_id = '$node' AND metric_type IN ('network.bytes_sent', 'network.bytes_recv') ORDER BY collected_at;"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes", "custom": { "drawStyle": "line" } }, "overrides": [] }
    }
  ]
}
