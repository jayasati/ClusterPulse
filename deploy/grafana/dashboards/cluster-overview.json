{
  "uid": "clusterpulse-overview",
  "title": "ClusterPulse - Cluster Overview",
  "tags": ["clusterpulse"],
  "timezone": "utc",
  "schemaVersion": 39,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Registered Nodes",
      "gridPos": { "h": 5, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "clusterpulse-postgres" },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT count(*) AS nodes FROM nodes;"
        }
      ],
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "blue" } }, "overrides": [] }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Stale Nodes (no push in 90s)",
      "gridPos": { "h": 5, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "clusterpulse-postgres" },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT count(*) AS stale FROM nodes WHERE last_seen_at < now() - interval '90 seconds';"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "red", "value": 1 } ] }
        },
        "overrides": []
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Firing Alerts",
      "gridPos": { "h": 5, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "clusterpulse-postgres" },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT count(*) AS firing FROM alerts WHERE status = 'firing';"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "orange", "value": 1 }, { "color": "red", "value": 3 } ] }
        },
        "overrides": []
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Remediations (24h)",
      "gridPos": { "h": 5, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "clusterpulse-postgres" },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT count(*) AS remediations FROM remediation_actions WHERE created_at > now() - interval '24 hours';"
        }
      ],
      "fieldConfig": { "defaults": {}, "overrides": [] }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Metric Ingest Rate (samples/min)",
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 5 },
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "clusterpulse-postgres" },
      "targets": [
        {
          "refId": "A",
          "format": "time_series",
          "rawSql": "SELECT $__timeGroup(received_at, '1m') AS time, count(*) AS samples FROM metric_samples WHERE $__timeFilter(received_at) GROUP BY 1 ORDER BY 1;"
        }
      ],
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "fillOpacity": 12 } }, "overrides": [] }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "CPU Usage by Node (%)",
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 5 },
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "clusterpulse-postgres" },
      "targets": [
        {
          "refId": "A",
          "format": "time_series",
          "rawSql": "SELECT $__time(collected_at), node_id AS metric, value FROM metric_samples WHERE $__timeFilter(collected_at) AND metric_type = 'cpu.usage_percent' ORDER BY collected_at;"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "percent", "max": 100, "min": 0, "custom": { "drawStyle": "line" } }, "overrides": [] }
    },
    {
      "id": 7,
      "type": "table",
      "title": "Node Registry",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 14 },
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "clusterpulse-postgres" },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT node_id, first_seen_at, last_seen_at, (last_seen_at < now() - interval '90 seconds') AS is_stale FROM nodes ORDER BY last_seen_at DESC;"
        }
      ],
      "fieldConfig": { "defaults": {}, "overrides": [] }
    }
  ]
}
